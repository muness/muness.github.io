direction: down

grid-columns: 2

defaults: {
  shape: rectangle
  style: {
    font-size: 22
    stroke-width: 2
    fill: "#ffffff"
    stroke: "#1e293b"
  }
}

start: "What kind of ranking failure are you seeing?"

semantic: "Query words differ from the right answer"
exact: "Exact terms matter\n(credentials, acronyms, procedures)"
diverse: "Top results feel too similar"
ambiguous: "The query is vague or constraint-heavy"
trust: "People need to understand\nwhy this result appeared"

vector: "Use semantic retrieval\n(vector search)"
fts: "Use lexical retrieval\n(full-text search)"
mmr: "Use diversification\n(MMR)"
analysis: "Use query analysis\n(rewrite intent, extract concepts)"
diagnostics: "Expose diagnostics\n(ranks, boosts, penalties, rerank)"

fusion: "Combine signals with RRF"
rerank: "Use reranking after cheap retrieval narrows the field"
structured: "Add structured boosts / penalties\nfor domain-specific signals"

note: {
  shape: text
  style: {
    font-size: 18
    italic: true
    font-color: "#475569"
  }
  label: "Typical pattern: semantic + lexical → fuse → rerank → diversify"
}

start -> semantic
start -> exact
start -> diverse
start -> ambiguous
start -> trust

semantic -> vector
exact -> fts
ambiguous -> analysis
trust -> diagnostics
diverse -> mmr

vector -> fusion
fts -> fusion
analysis -> fusion
fusion -> structured
structured -> rerank
rerank -> mmr
mmr -> diagnostics

diagnostics -> note
