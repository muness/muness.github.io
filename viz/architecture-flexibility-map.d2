direction: down

vars: {
  stroke: "#1E293B"
  accent: "#64748B"
  text: "#0F172A"
  lane: "#F8FAFC"
}

classes: {
  box: {
    style: {
      stroke: ${stroke}
      stroke-width: 2
      font-color: ${text}
      font-size: 16
      bold: true
      fill: "#FFFFFF"
    }
  }
  lane: {
    style: {
      stroke: ${accent}
      stroke-width: 2
      font-color: ${text}
      font-size: 18
      bold: true
      fill: ${lane}
    }
  }
  edge: {
    style: {
      stroke: ${accent}
      stroke-width: 2
      font-color: ${accent}
      font-size: 14
    }
  }
}

enterprise: {
  class: lane
  label: "Enterprise"
  direction: right

  ent_before: {
    class: box
    label: "Monolith /\nmono-agent"
  }

  ent_after: {
    class: box
    label: "Decomposed\nservices + agents"
  }

  ent_outcome: {
    class: box
    label: "Inspectable\nhand-offs +\nreliable gates"
  }

  ent_before -> ent_after: {class: edge}
  ent_after -> ent_outcome: {class: edge}
}

oss: {
  class: lane
  label: "OSS"
  direction: right

  oss_before: {
    class: box
    label: "Node + bespoke\nUI"
  }

  oss_after: {
    class: box
    label: "Rust core +\nbus + adapters"
  }

  oss_outcome: {
    class: box
    label: "Single binary +\nmore delivery paths"
  }

  oss_before -> oss_after: {class: edge}
  oss_after -> oss_outcome: {class: edge}
}

leaders: {
  class: box
  label: "Flexibility keeps\ndelivery paths open"
}

enterprise.ent_outcome -> leaders: {class: edge}
oss.oss_outcome -> leaders: {class: edge}
