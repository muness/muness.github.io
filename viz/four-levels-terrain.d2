direction: right

vars: {
  stroke: "#1E293B"
  accent: "#64748B"
  text: "#0F172A"
}

classes: {
  level: {
    style: {
      stroke: ${stroke}
      stroke-width: 2
      font-color: ${text}
      font-size: 14
      fill: "#FFFFFF"
    }
  }
  edge: {
    style: {
      stroke: ${accent}
      stroke-width: 2
      font-color: ${accent}
      font-size: 12
    }
  }
  axis: {
    style: {
      stroke: ${accent}
      stroke-width: 1
      stroke-dash: 4
      font-color: ${accent}
      font-size: 11
      fill: "transparent"
    }
  }
}

tarp: {
  class: level
  label: "Tarp\npatch symptom"
}

peak: {
  class: level
  label: "Nearest peak\nlocal optimize"
}

beyond: {
  class: level
  label: "Beyond nearest peak\nreframe solution"
}

terraform: {
  class: level
  label: "Terraform\nchange terrain"
  style.fill: "#F8FAFC"
  style.stroke-width: 3
}

tarp -> peak: {class: edge}
peak -> beyond: {class: edge}
beyond -> terraform: {class: edge}

axis: {
  class: axis
  label: "Shift in leverage"
}

low: {
  class: axis
  label: "artifact tweaks"
}

high: {
  class: axis
  label: "environment design"
}

axis -> low: "" {style.stroke-dash: 4; style.stroke: "#64748B"}
axis -> high: "" {style.stroke-dash: 4; style.stroke: "#64748B"}
low -> tarp: "" {style.stroke-dash: 4; style.stroke: "#64748B"}
high -> terraform: "" {style.stroke-dash: 4; style.stroke: "#64748B"}
