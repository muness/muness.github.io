direction: right

vars: {
  stroke: "#1E293B"
  accent: "#64748B"
  text: "#0F172A"
}

classes: {
  box: {
    style: {
      stroke: ${stroke}
      stroke-width: 2
      font-color: ${text}
      font-size: 16
      fill: "#FFFFFF"
    }
  }
  decision: {
    shape: diamond
    style: {
      stroke: ${stroke}
      stroke-width: 2
      font-color: ${text}
      font-size: 14
      fill: "#F8FAFC"
    }
  }
  edge: {
    style: {
      stroke: ${accent}
      stroke-width: 2
      font-color: ${accent}
      font-size: 12
    }
  }
}

preflight: {
  class: box
  label: "Pre-flight\n(aim + constraints + done-when)"
}

build: {
  class: box
  label: "Build\n(execute)"
}

detect: {
  class: decision
  label: "Drift?"
}

salvage: {
  class: box
  label: "Salvage\n(extract learning)"
}

ship: {
  class: box
  label: "Ship / Restart\n(deliver or reset)"
}

preflight -> build: {class: edge}
build -> detect: {class: edge}
detect -> ship: "Aligned" {class: edge}
detect -> salvage: "Drifting" {class: edge}
salvage -> preflight: "Restart clean" {class: edge}
ship -> preflight: "Next cycle" {class: edge}
